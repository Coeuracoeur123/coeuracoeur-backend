# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret

# ─── SSH Tunnel ───────────────────────────────────────────
# The server you SSH into (same machine that hosts MySQL)
SSH_HOST=your.server.com
SSH_PORT=22
SSH_USER=your_ssh_username
# Absolute path to your private key file (no passphrase, or use SSH_PASSWORD below)
SSH_PRIVATE_KEY_PATH=/home/youruser/.ssh/id_rsa
# Uncomment if using password auth instead of a key:
# SSH_PASSWORD=your_ssh_password

# Local port the tunnel will bind on your machine
SSH_LOCAL_PORT=3307

# ─── MySQL (via tunnel) ───────────────────────────────────
# MySQL host as seen FROM the SSH server — usually 127.0.0.1
DB_REMOTE_HOST=127.0.0.1
# Remote MySQL port (forwarded through the tunnel)
DB_PORT=3306
# Local port to probe for a direct MySQL connection (no tunnel). If this port
# responds, the SSH tunnel is skipped entirely. Distinct from DB_PORT, which is
# the remote port. They are both 3306 by default but diverge when MySQL runs on
# a non-standard port on the remote host.
DB_LOCAL_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
